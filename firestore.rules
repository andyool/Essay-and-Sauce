rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Teachers: the built-in address below, plus any addresses the dashboard
    // has saved to config/teachers (Classes tab → Teachers).
    function isTeacher() {
      return request.auth != null
        && request.auth.token.email != null
        && (request.auth.token.email == 'andreas.beerli@hotmail.com'
            || (exists(/databases/$(database)/documents/config/teachers)
                && request.auth.token.email in
                   get(/databases/$(database)/documents/config/teachers).data.emails));
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // The caller's stable student identity (class + name), as registered in
    // their student profile. Lets a student who signed out and back in (new
    // session, same name) reconnect to their own attempts.
    function callerKey() {
      return get(/databases/$(database)/documents/students/$(request.auth.uid)).data.studentKey;
    }

    // Site configuration (currently just the extra-teachers list). Readable
    // only by password (teacher) accounts, writable by teachers.
    match /config/{docId} {
      allow read: if request.auth != null && request.auth.token.email != null;
      allow write: if isTeacher();
    }

    // Name-PIN claims: the first sign-in under a name creates the claim; it
    // can never be changed by students, so the PIN chosen then guards the
    // name. The teacher may delete a claim to reset a student's PIN.
    match /identities/{key} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.studentKey == key
        && request.resource.data.pinHash is string;
      allow update: if false;
      allow delete: if isTeacher();
    }

    // Classes: any signed-in user may look up a class by its join code;
    // only the teacher may create or change classes.
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher();
    }

    // Student profiles: each session may manage only its own profile, and
    // writing a profile requires presenting the PIN (hash) that matches the
    // name's claim — this is what stops a classmate taking over a name.
    match /students/{uid} {
      allow read: if isTeacher() || (isSignedIn() && request.auth.uid == uid);
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.pinHash ==
           get(/databases/$(database)/documents/identities/$(request.resource.data.studentKey)).data.pinHash;
      allow delete: if isTeacher();
    }

    // Attempts: a student may access attempts created in this session
    // (studentUid) or in any earlier session under the same name in the same
    // class (studentKey). The identity fields themselves are immutable.
    match /attempts/{attemptId} {
      allow read: if isTeacher()
        || (isSignedIn()
            && (resource.data.studentUid == request.auth.uid
                || resource.data.studentKey == callerKey()));
      allow create: if isSignedIn()
        && request.resource.data.studentUid == request.auth.uid
        && request.resource.data.studentKey == callerKey();
      // The teacher may update only the feedback (marks/comments); students
      // may update their own work but never the feedback field.
      allow update: if (isTeacher()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['feedback', 'updatedAt']))
        || (isSignedIn()
            && (resource.data.studentUid == request.auth.uid
                || resource.data.studentKey == callerKey())
            && request.resource.data.studentUid == resource.data.studentUid
            && request.resource.data.studentKey == resource.data.studentKey
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['feedback']));
      allow delete: if isTeacher()
        || (isSignedIn()
            && (resource.data.studentUid == request.auth.uid
                || resource.data.studentKey == callerKey()));
    }
  }
}
