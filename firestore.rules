rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacher() {
      return request.auth != null
        && request.auth.token.email == 'andreas.beerli@hotmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // The caller's stable student identity (class + name), as registered in
    // their student profile. Lets a student who signed out and back in (new
    // session, same name) reconnect to their own attempts.
    function callerKey() {
      return get(/databases/$(database)/documents/students/$(request.auth.uid)).data.studentKey;
    }

    // Classes: any signed-in user may look up a class by its join code;
    // only the teacher may create or change classes.
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isTeacher();
    }

    // Student profiles: each session may manage only its own profile;
    // the teacher may read all.
    match /students/{uid} {
      allow read: if isTeacher() || (isSignedIn() && request.auth.uid == uid);
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isTeacher();
    }

    // Attempts: a student may access attempts created in this session
    // (studentUid) or in any earlier session under the same name in the same
    // class (studentKey). The identity fields themselves are immutable.
    match /attempts/{attemptId} {
      allow read: if isTeacher()
        || (isSignedIn()
            && (resource.data.studentUid == request.auth.uid
                || resource.data.studentKey == callerKey()));
      allow create: if isSignedIn()
        && request.resource.data.studentUid == request.auth.uid
        && request.resource.data.studentKey == callerKey();
      allow update: if isSignedIn()
        && (resource.data.studentUid == request.auth.uid
            || resource.data.studentKey == callerKey())
        && request.resource.data.studentUid == resource.data.studentUid
        && request.resource.data.studentKey == resource.data.studentKey;
      allow delete: if isTeacher()
        || (isSignedIn()
            && (resource.data.studentUid == request.auth.uid
                || resource.data.studentKey == callerKey()));
    }
  }
}
